# JetBrains Rider / CLion
.idea/
*.Rider.Module.xml
*.sln.DotSettings.user

# Visual Studio user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# CMake / CLion build directories (For FSW_Standalone)
cmake-build-*/
build/
out/

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# ---------------------------------------------------
# UNREAL ENGINE SPECIFIC (Plant_Unreal)
# ---------------------------------------------------

# Binary Files
Plant_Unreal/Binaries/*
Plant_Unreal/Plugins/**/Binaries/*

# Compiled source files for the engine to use
Plant_Unreal/Intermediate/*
Plant_Unreal/Plugins/**/Intermediate/*

# Builds
Plant_Unreal/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Plant_Unreal/Build/*/
Plant_Unreal/Build/*/**
!Plant_Unreal/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Plant_Unreal/Build/**/*.ico

# Built data for maps
Plant_Unreal/*_BuiltData.uasset

# Configuration files generated by the Editor
Plant_Unreal/Saved/*

# Cache files for the editor to use
Plant_Unreal/DerivedDataCache/*